---
import about from '../../content/about.json';
---

<section id="om-oss" class="about">
  <div class="about-inner">
    <div class="about-text">
      <p class="label">Om oss</p>
      <h2>{about.heading}</h2>
      <div class="body">
        <p>{about.body}</p>
        <p>{about.body2}</p>
        <p>{about.body3}</p>
        <p class="emphasis">{about.closing}</p>
      </div>
    </div>
    <div class="about-images">
      <img src="/assets/betty-action.png" alt="Barberare med trimmer hos Society Barber" class="img-tall" loading="lazy">
      <img src="/assets/amir-beard.png" alt="Skäggvård hos Society Barber" class="img-small" loading="lazy">
      <img src="/assets/beard-trim.png" alt="Skäggtrimning hos Society Barber" class="img-small" loading="lazy">
    </div>
  </div>
</section>

<style>
  .about {
    background: #EFE9DC;
    color: #24382E;
    padding: clamp(70px, 9vw, 130px) 24px;
    scroll-margin-top: 70px;
  }
  .about-inner {
    max-width: 1240px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: clamp(40px, 6vw, 90px);
    align-items: center;
  }
  .label {
    font-family: 'Jost', sans-serif;
    font-size: 13px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: rgba(36, 56, 46, 0.55);
    margin-bottom: 20px;
  }
  h2 {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 600;
    font-size: clamp(32px, 4.4vw, 52px);
    line-height: 1.05;
    letter-spacing: -0.01em;
    max-width: 16ch;
  }
  .body {
    margin-top: 28px;
    font-family: 'Jost', sans-serif;
    font-size: 16px;
    line-height: 1.75;
    font-weight: 300;
    color: rgba(36, 56, 46, 0.86);
    max-width: 60ch;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .emphasis {
    font-weight: 400;
    color: #24382E;
  }
  .about-images {
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-template-rows: 1fr 1fr;
    gap: 14px;
    aspect-ratio: 1 / 1;
    min-width: 0;
  }
  .about-images img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 3px;
  }
  .img-tall {
    grid-row: 1 / 3;
  }
  .img-small {
    /* sits in column 2, rows 1 and 2 auto */
  }
  @media (max-width: 700px) {
    .about-images { aspect-ratio: auto; min-height: 360px; }
  }
</style>
