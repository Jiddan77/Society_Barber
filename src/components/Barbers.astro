---
import fs from 'node:fs';
import path from 'node:path';
import settings from '../../content/settings.json';

const barbersDir = path.resolve('content/barbers');
const barbers = fs.readdirSync(barbersDir)
  .filter(f => f.endsWith('.json'))
  .map(f => JSON.parse(fs.readFileSync(path.join(barbersDir, f), 'utf-8')))
  .sort((a, b) => a.order - b.order);
---

<section id="team" class="team">
  <div class="team-inner">
    <div class="team-header">
      <p class="label">Vårt team</p>
      <h2>Möt dina barberare</h2>
    </div>
    <div class="team-grid">
      {barbers.map((b) => (
        <article class="barber-card">
          <div class="photo-wrap">
            <img src={b.photo} alt={`${b.name} klipper en kund hos Society Barber i Åkersberga`} loading="lazy">
          </div>
          <div class="info">
            <h3>{b.name}</h3>
            <p class="subtitle">{b.title}</p>
            <p class="bio">{b.bio}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .team {
    background: #EFE9DC;
    color: #24382E;
    padding: clamp(70px, 9vw, 130px) 24px;
    scroll-margin-top: 70px;
  }
  .team-inner {
    max-width: 1240px;
    margin: 0 auto;
  }
  .team-header {
    max-width: 680px;
    margin-bottom: clamp(40px, 5vw, 64px);
  }
  .label {
    font-family: 'Jost', sans-serif;
    font-size: 13px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: rgba(36, 56, 46, 0.55);
    margin-bottom: 18px;
  }
  h2 {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 600;
    font-size: clamp(32px, 4.6vw, 56px);
    line-height: 1.04;
    letter-spacing: -0.01em;
  }
  .team-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 28px;
  }
  .barber-card {
    background: #FBF8F1;
    border: 1px solid rgba(36, 56, 46, 0.12);
    border-radius: 6px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }
  .photo-wrap {
    aspect-ratio: 4 / 5;
    overflow: hidden;
    background: #24382E;
  }
  .photo-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
  }
  .info {
    padding: clamp(26px, 3vw, 36px) clamp(26px, 3vw, 38px) clamp(32px, 3.5vw, 42px);
  }
  h3 {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 600;
    font-size: 32px;
    color: #24382E;
  }
  .subtitle {
    font-family: 'Jost', sans-serif;
    font-size: 12px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(36, 56, 46, 0.5);
    margin-top: 6px;
  }
  .bio {
    font-family: 'Jost', sans-serif;
    font-size: 15px;
    line-height: 1.65;
    font-weight: 300;
    color: rgba(36, 56, 46, 0.82);
    margin-top: 16px;
    max-width: 42ch;
  }
  @media (max-width: 680px) {
    .team-grid { grid-template-columns: 1fr; }
  }
</style>
