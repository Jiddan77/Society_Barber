---
import fs from 'node:fs';
import path from 'node:path';
import settings from '../../content/settings.json';

const barbersDir = path.resolve('content/barbers');
const barbers = fs.readdirSync(barbersDir)
  .filter(f => f.endsWith('.json'))
  .map(f => JSON.parse(fs.readFileSync(path.join(barbersDir, f), 'utf-8')))
  .sort((a, b) => a.order - b.order);
---

<section class="section barbers-section" id="barberare">
  <div class="container">
    <p class="section-label">Teamet</p>
    <h2>Möt våra barberare</h2>
    <div class="divider"></div>

    <div class="barbers-grid">
      {barbers.map((b) => (
        <article class="barber-card">
          <p class="barber-specialty">{b.specialty}</p>
          <h3>{b.name}</h3>
          <p class="barber-title">{b.title}</p>
          <div class="divider"></div>
          <p class="barber-bio">{b.bio}</p>
          <a href={settings.booking_url} class="btn btn-outline barber-cta" target="_blank" rel="noopener">Boka med {b.name}</a>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  h2 { font-size: clamp(2.2rem, 4vw, 3.2rem); }
  .barbers-section { scroll-margin-top: 80px; }
  .barbers-grid {
    margin-top: 4rem;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0;
    border-top: 1px solid var(--border);
  }
  .barber-card {
    padding: 4rem 4rem 4rem 0;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
  .barber-card + .barber-card {
    padding-left: 4rem;
    padding-right: 0;
    border-left: 1px solid var(--border);
  }
  .barber-specialty {
    font-size: 0.68rem;
    font-weight: 500;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 0.75rem;
  }
  h3 {
    font-size: clamp(3rem, 5vw, 4.5rem);
    font-weight: 500;
    line-height: 1.05;
  }
  .barber-title {
    font-size: 0.72rem;
    font-weight: 400;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--text-muted);
  }
  .barber-bio {
    font-size: 0.95rem;
    line-height: 1.75;
    color: rgba(240, 234, 216, 0.75);
    max-width: 420px;
    margin-top: 0.5rem;
    margin-bottom: 0.5rem;
  }
  .barber-cta { margin-top: 1rem; }
  @media (max-width: 768px) {
    .barbers-grid { grid-template-columns: 1fr; }
    .barber-card { padding: 3rem 0; }
    .barber-card + .barber-card {
      padding-left: 0;
      border-left: none;
      border-top: 1px solid var(--border);
    }
  }
</style>
