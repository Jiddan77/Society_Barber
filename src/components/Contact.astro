---
import settings from '../../content/settings.json';
import hoursData from '../../content/hours.json';
---

<footer id="kontakt" class="contact">
  <div class="contact-inner">
    <div class="contact-grid">
      <div class="contact-left">
        <p class="label">Hitta hit &amp; boka tid</p>
        <h2>Välkommen in till Society Barber</h2>
        <a href={settings.booking_url} target="_blank" rel="noopener" class="book-btn">Boka Tid</a>
      </div>

      <div class="contact-right">
        <div class="info-col">
          <h3 class="info-heading">Besök oss</h3>
          <p class="info-body">
            <a href="https://www.google.com/maps/search/?api=1&query=Rallarvägen+43,+184+40,+Åkersberga" target="_blank" rel="noopener" class="map-link">
              Rallarvägen 43<br>184 40 Åkersberga
            </a>
          </p>
        </div>
        <div class="info-col">
          <h3 class="info-heading">Kontakt</h3>
          <p class="info-body info-links">
            <a href={`mailto:${settings.email}`}>{settings.email}</a><br>
            <a href={`tel:${settings.phone.replace(/-/g,'')}`}>{settings.phone}</a><br>
            <a href="https://www.societybarber.se">www.societybarber.se</a>
          </p>
        </div>
        <div class="info-col">
          <h3 class="info-heading">Öppettider</h3>
          <div class="hours">
            {hoursData.hours.map(h => (
              <div class="hours-row">
                <span>{h.day}</span>
                <span class="hours-time">{h.open}–{h.close}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>

    <div class="exterior-wrap">
      <img src="/assets/exterior-sign.png" alt="Society Barber skylt i Åkersberga" loading="lazy" class="exterior-img">
    </div>

    <div class="copyright">
      <span>© {new Date().getFullYear()} Society Barber. Alla rättigheter förbehållna.</span>
      <span>{settings.address}</span>
    </div>
  </div>
</footer>

<style>
  .contact {
    background: #1A2A22;
    color: #EFE9DC;
    padding: clamp(70px, 9vw, 120px) 24px 40px;
    scroll-margin-top: 70px;
  }
  .contact-inner {
    max-width: 1240px;
    margin: 0 auto;
  }
  .contact-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: clamp(36px, 5vw, 70px);
    align-items: start;
  }
  .label {
    font-family: 'Jost', sans-serif;
    font-size: 13px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: rgba(239, 233, 220, 0.55);
    margin-bottom: 18px;
  }
  h2 {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 600;
    font-size: clamp(34px, 5vw, 60px);
    line-height: 1.02;
    letter-spacing: -0.01em;
    max-width: 14ch;
  }
  .book-btn {
    display: inline-block;
    margin-top: 30px;
    background: #EFE9DC;
    color: #24382E;
    text-decoration: none;
    font-family: 'Jost', sans-serif;
    font-size: 15px;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 18px 40px;
    border-radius: 2px;
    transition: transform 0.2s, box-shadow 0.25s;
  }
  .book-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 14px 30px rgba(0,0,0,0.4);
  }
  .contact-right {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
    gap: 32px;
  }
  .info-heading {
    font-family: 'Jost', sans-serif;
    font-size: 12px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(239, 233, 220, 0.5);
    margin-bottom: 16px;
    font-weight: 500;
  }
  .info-body {
    font-family: 'Jost', sans-serif;
    font-size: 16px;
    line-height: 1.7;
    font-weight: 300;
  }
  .info-links {
    font-size: 15px;
    line-height: 1.9;
  }
  .info-links a, .map-link {
    color: #EFE9DC;
    text-decoration: none;
    border-bottom: 1px solid rgba(239, 233, 220, 0.3);
    transition: border-color 0.2s;
  }
  .info-links a:hover, .map-link:hover { border-color: #EFE9DC; }
  .hours {
    font-family: 'Jost', sans-serif;
    font-size: 15px;
    font-weight: 300;
    display: flex;
    flex-direction: column;
    gap: 11px;
  }
  .hours-row {
    display: flex;
    justify-content: space-between;
    gap: 14px;
  }
  .hours-time { color: rgba(239, 233, 220, 0.7); }
  .exterior-wrap {
    margin-top: clamp(44px, 6vw, 72px);
    border-radius: 4px;
    overflow: hidden;
  }
  .exterior-img {
    width: 100%;
    height: clamp(220px, 32vw, 380px);
    object-fit: cover;
    object-position: center 40%;
    display: block;
  }
  .copyright {
    margin-top: 40px;
    padding-top: 26px;
    border-top: 1px solid rgba(239, 233, 220, 0.12);
    display: flex;
    justify-content: space-between;
    gap: 16px;
    flex-wrap: wrap;
    font-family: 'Jost', sans-serif;
    font-size: 13px;
    color: rgba(239, 233, 220, 0.5);
    letter-spacing: 0.04em;
  }
</style>
