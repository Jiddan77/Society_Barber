---
import settings from '../../content/settings.json';
import hoursData from '../../content/hours.json';
const { hours } = hoursData;
---

<section class="section" id="kontakt">
  <div class="container">
    <div class="contact-grid">
      <div class="contact-info">
        <p class="section-label">Kontakt & Hitta oss</p>
        <h2>Välkommen in</h2>
        <div class="divider"></div>

        <div class="info-block">
          <p class="info-label">Adress</p>
          <p>{settings.address}</p>
        </div>

        <div class="info-block">
          <p class="info-label">Telefon</p>
          <a href={`tel:${settings.phone.replace(/-/g,'')}`}>{settings.phone}</a>
        </div>

        <div class="info-block">
          <p class="info-label">E-post</p>
          <a href={`mailto:${settings.email}`}>{settings.email}</a>
        </div>

        <div class="info-block">
          <p class="info-label">Öppettider</p>
          <ul class="hours-list">
            {hours.map((h) => (
              <li>
                <span class="hours-day">{h.day}</span>
                <span class="hours-time">{h.open}–{h.close}</span>
              </li>
            ))}
          </ul>
        </div>

        <a href={settings.booking_url} class="btn btn-primary" target="_blank" rel="noopener" style="margin-top:1.5rem">
          Boka tid online
        </a>
      </div>

      <div class="contact-map">
        <iframe
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2009.2!2d18.276!3d59.486!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x465f9c7c0c0c0c0c%3A0x0!2sRallarv%C3%A4gen+43%2C+184+40+%C3%85kersberga!5e0!3m2!1ssv!2sse!4v1"
          width="100%"
          height="100%"
          style="border:0;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Society Barber karta"
        ></iframe>
      </div>
    </div>
  </div>
</section>

<style>
  h2 { font-size: clamp(2.2rem, 4vw, 3.2rem); }
  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
    align-items: start;
  }
  .info-block { margin-top: 1.75rem; }
  .info-label {
    font-size: 0.68rem;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 0.4rem;
  }
  .info-block p, .info-block a {
    font-size: 1rem;
    line-height: 1.6;
  }
  .info-block a:hover { color: var(--accent); }
  .hours-list { list-style: none; }
  .hours-list li {
    display: flex;
    justify-content: space-between;
    gap: 2rem;
    padding: 0.4rem 0;
    border-bottom: 1px solid var(--border);
    font-size: 0.9rem;
  }
  .hours-day { color: rgba(240, 234, 216, 0.8); }
  .hours-time { color: var(--accent); }
  .contact-map {
    height: 480px;
    overflow: hidden;
  }
  .contact-map iframe { filter: grayscale(30%) invert(5%); }
  @media (max-width: 900px) {
    .contact-grid { grid-template-columns: 1fr; gap: 3rem; }
    .contact-map { height: 320px; }
  }
</style>
