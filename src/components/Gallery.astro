---
const photos = [
  { src: '/assets/betty-cut.png', alt: 'Betty klipper en kund' },
  { src: '/assets/amir-beard.png', alt: 'Amir rakar skägg' },
  { src: '/assets/betty-beard.png', alt: 'Betty skäggtrimning' },
  { src: '/assets/amir-mirror.png', alt: 'Amir spegelbild' },
  { src: '/assets/clipper-outdoor.png', alt: 'Klippning utomhus' },
  { src: '/assets/exterior-sign.png', alt: 'Society Barber exteriör' },
];
---

<section class="section" id="galleri">
  <div class="container">
    <p class="section-label">Galleri</p>
    <h2>Hantverk i fokus</h2>
    <div class="divider"></div>
  </div>

  <div class="gallery-grid">
    {photos.map((p) => (
      <div class="gallery-item">
        <img src={p.src} alt={p.alt} loading="lazy">
      </div>
    ))}
  </div>
</section>

<style>
  .container h2 { font-size: clamp(2.2rem, 4vw, 3.2rem); }
  .gallery-grid {
    margin-top: 3rem;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 3px;
  }
  .gallery-item {
    aspect-ratio: 1;
    overflow: hidden;
  }
  .gallery-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }
  .gallery-item:hover img { transform: scale(1.04); }
  @media (max-width: 640px) {
    .gallery-grid { grid-template-columns: repeat(2, 1fr); }
  }
</style>
