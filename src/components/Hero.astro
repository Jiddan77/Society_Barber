---
import settings from '../../content/settings.json';
---

<section class="hero" id="top">
  <img src={settings.hero_image} alt="Barberare i arbete hos Society Barber" loading="eager" fetchpriority="high" class="hero-img">
  <div class="overlay-linear"></div>
  <div class="overlay-radial"></div>

  <div class="hero-content">
    <p class="hero-label">Society Barber &nbsp;·&nbsp; Åkersberga</p>
    <h1>
      {settings.tagline}
      <span class="hero-sub">— Society Barber</span>
    </h1>
    <p class="hero-desc">{settings.hero_subtitle}</p>
    <div class="hero-actions">
      <a href={settings.booking_url} class="btn-primary" target="_blank" rel="noopener">Boka Tid</a>
      <a href="#tjanster" class="hero-link">Se tjänster &amp; priser</a>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 92vh;
    display: flex;
    align-items: flex-end;
    overflow: hidden;
    background: #1A2A22;
  }
  .hero-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 30%;
  }
  .overlay-linear {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(26,42,34,0.55) 0%, rgba(26,42,34,0.35) 38%, rgba(26,42,34,0.92) 100%);
  }
  .overlay-radial {
    position: absolute;
    inset: 0;
    background: radial-gradient(120% 80% at 15% 100%, rgba(26,42,34,0.7), transparent 60%);
  }
  .hero-content {
    position: relative;
    z-index: 2;
    max-width: 1240px;
    width: 100%;
    margin: 0 auto;
    padding: 0 24px 72px;
  }
  .hero-label {
    font-family: 'Jost', sans-serif;
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(239, 233, 220, 0.7);
    margin-bottom: 20px;
  }
  h1 {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(44px, 8vw, 92px);
    font-weight: 600;
    line-height: 1.04;
    letter-spacing: -0.01em;
    max-width: 14ch;
    color: #EFE9DC;
    display: flex;
    flex-direction: column;
  }
  .hero-sub {
    font-family: 'Jost', sans-serif;
    font-size: 0.42em;
    font-weight: 400;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: rgba(239, 233, 220, 0.7);
    margin-top: 18px;
  }
  .hero-desc {
    font-family: 'Jost', sans-serif;
    font-size: 16px;
    font-weight: 300;
    line-height: 1.7;
    color: rgba(239, 233, 220, 0.8);
    max-width: 520px;
    margin: 28px 0 36px;
  }
  .hero-actions {
    display: flex;
    align-items: center;
    gap: 28px;
    flex-wrap: wrap;
  }
  .btn-primary {
    display: inline-block;
    background: #EFE9DC;
    color: #24382E;
    text-decoration: none;
    font-family: 'Jost', sans-serif;
    font-size: 15px;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 18px 40px;
    border-radius: 2px;
    transition: transform 0.2s, box-shadow 0.25s;
  }
  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 14px 30px rgba(0,0,0,0.4);
  }
  .hero-link {
    font-family: 'Jost', sans-serif;
    font-size: 14px;
    font-weight: 400;
    letter-spacing: 0.1em;
    color: rgba(239, 233, 220, 0.85);
    text-decoration: none;
    border-bottom: 1px solid rgba(239, 233, 220, 0.4);
    padding-bottom: 2px;
    transition: border-color 0.2s, color 0.2s;
  }
  .hero-link:hover {
    color: #EFE9DC;
    border-color: #EFE9DC;
  }
  @media (max-width: 640px) {
    .hero-content { padding-bottom: 52px; }
  }
</style>
