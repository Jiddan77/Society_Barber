---
import settings from '../../content/settings.json';
---

<section class="hero">
  <div class="hero-media">
    <img src={settings.hero_image} alt="Barberare i arbete hos Society Barber" loading="eager" fetchpriority="high">
    <div class="hero-overlay"></div>
  </div>

  <div class="hero-content container">
    <p class="hero-label">Society Barber &nbsp;·&nbsp; Åkersberga</p>
    <h1>{settings.tagline}</h1>
    <p class="hero-sub">— Society Barber —</p>
    <p class="hero-desc">{settings.hero_subtitle}</p>
    <div class="hero-actions">
      <a href={settings.booking_url} class="btn btn-primary" target="_blank" rel="noopener">Boka tid</a>
      <a href="#tjanster" class="hero-link">Se tjänster &amp; priser</a>
    </div>
  </div>

  <div class="hero-footer container">
    <span>{settings.address}</span>
    <span class="sep">|</span>
    <span>Mån–Fre 09–18 &nbsp;·&nbsp; Lör 10–17 &nbsp;·&nbsp; Sön 11–16</span>
    <span class="sep">|</span>
    <span>Drop-in &amp; bokning</span>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  .hero-media {
    position: absolute;
    inset: 0;
    overflow: hidden;
  }
  .hero-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
  }
  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to right,
      rgba(26, 42, 34, 0.88) 0%,
      rgba(26, 42, 34, 0.60) 50%,
      rgba(26, 42, 34, 0.30) 100%
    );
  }
  .hero-content {
    position: relative;
    z-index: 2;
    padding-top: 8rem;
    max-width: 680px;
  }
  .hero-label {
    font-size: 0.68rem;
    font-weight: 500;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 1.25rem;
  }
  h1 {
    font-size: clamp(3rem, 7vw, 5.5rem);
    font-weight: 500;
    line-height: 1.05;
    margin-bottom: 0.75rem;
  }
  .hero-sub {
    font-family: 'Jost', sans-serif;
    font-size: 0.7rem;
    font-weight: 400;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 1.5rem;
  }
  .hero-desc {
    font-size: 1rem;
    font-weight: 300;
    line-height: 1.7;
    color: rgba(240, 234, 216, 0.75);
    max-width: 480px;
    margin-bottom: 2.5rem;
  }
  .hero-actions {
    display: flex;
    align-items: center;
    gap: 2rem;
    flex-wrap: wrap;
  }
  .hero-link {
    font-size: 0.75rem;
    font-weight: 400;
    letter-spacing: 0.1em;
    border-bottom: 1px solid var(--text-muted);
    padding-bottom: 2px;
    transition: border-color 0.2s;
  }
  .hero-link:hover { border-color: var(--text); }
  .hero-footer {
    position: relative;
    z-index: 2;
    display: flex;
    align-items: center;
    gap: 1.25rem;
    flex-wrap: wrap;
    padding-bottom: 2rem;
    margin-top: auto;
    font-size: 0.72rem;
    font-weight: 400;
    letter-spacing: 0.06em;
    color: rgba(240, 234, 216, 0.55);
  }
  .sep { opacity: 0.3; }
  @media (max-width: 640px) {
    .hero-content { padding-top: 7rem; }
    .hero-footer { gap: 0.75rem; }
    .sep { display: none; }
    .hero-footer span { width: 100%; }
  }
</style>
