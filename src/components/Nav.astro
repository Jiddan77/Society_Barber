---
import settings from '../../content/settings.json';
---

<header class="nav-header" id="nav">
  <nav class="nav-inner">
    <a href="/" class="logo">
      <span class="logo-mark">SB</span>
      <span class="logo-text">Society Barber</span>
    </a>
    <button class="burger" id="burger" aria-label="Meny">
      <span></span><span></span><span></span>
    </button>
    <ul class="nav-links" id="nav-links">
      <li><a href="#tjanster">Tjänster</a></li>
      <li><a href="#om-oss">Om oss</a></li>
      <li><a href="#team">Team</a></li>
      <li><a href="#kontakt">Kontakt</a></li>
      <li><a href={settings.booking_url} class="nav-cta" target="_blank" rel="noopener">Boka Tid</a></li>
    </ul>
  </nav>
</header>

<style>
  .nav-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(26, 42, 34, 0.82);
    backdrop-filter: blur(14px);
    border-bottom: 1px solid rgba(239, 233, 220, 0.12);
  }
  .nav-inner {
    max-width: 1240px;
    margin: 0 auto;
    padding: 16px 24px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .logo {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-shrink: 0;
    text-decoration: none;
    color: #EFE9DC;
  }
  .logo-mark {
    width: 38px;
    height: 38px;
    border: 1px solid rgba(239, 233, 220, 0.7);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Cormorant Garamond', serif;
    font-size: 0.9rem;
    font-weight: 600;
    letter-spacing: 0.05em;
  }
  .logo-text {
    font-family: 'Jost', sans-serif;
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
  }
  .nav-links {
    display: flex;
    align-items: center;
    gap: 2rem;
    list-style: none;
  }
  .nav-links a:not(.nav-cta) {
    font-family: 'Jost', sans-serif;
    font-size: 0.75rem;
    font-weight: 400;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(239, 233, 220, 0.85);
    text-decoration: none;
    transition: color 0.2s;
  }
  .nav-links a:not(.nav-cta):hover { color: #EFE9DC; }
  .nav-cta {
    font-family: 'Jost', sans-serif;
    display: inline-block;
    background: #EFE9DC;
    color: #24382E;
    text-decoration: none;
    font-size: 14px;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 12px 26px;
    border-radius: 2px;
    transition: opacity 0.2s;
  }
  .nav-cta:hover { opacity: 0.88; }
  .burger {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
  }
  .burger span {
    display: block;
    width: 22px;
    height: 1px;
    background: #EFE9DC;
    transition: all 0.3s;
  }
  @media (max-width: 768px) {
    .burger { display: flex; }
    .nav-links {
      position: fixed;
      inset: 0;
      background: #1A2A22;
      flex-direction: column;
      justify-content: center;
      gap: 2rem;
      transform: translateX(100%);
      transition: transform 0.35s ease;
    }
    .nav-links.open { transform: translateX(0); }
    .nav-links a:not(.nav-cta) { font-size: 1rem; }
  }
</style>

<script>
  const burger = document.getElementById('burger');
  const links = document.getElementById('nav-links');

  burger?.addEventListener('click', () => {
    links?.classList.toggle('open');
  });

  links?.querySelectorAll('a').forEach(a => {
    a.addEventListener('click', () => links.classList.remove('open'));
  });
</script>
