---
import settings from '../../content/settings.json';
import svc from '../../content/services.json';
---

<section id="tjanster" class="services">
  <div class="services-inner">
    <div class="services-header">
      <p class="label">Tjänster &amp; priser</p>
      <h2>{svc.section_heading}</h2>
    </div>

    <div class="cards">

      <!-- Klippning -->
      <div class="card card-dark">
        <h3>Klippning</h3>
        <p class="card-sub">Herr-, barn- &amp; maskinklippning</p>
        <div class="items">
          {svc.klippning.map(item => (
            <div class="item">
              <div>
                <div class="item-name">{item.name}</div>
                {item.desc && <div class="item-desc">{item.desc}</div>}
              </div>
              <div class="item-price">{item.price}</div>
            </div>
          ))}
        </div>
      </div>

      <!-- Skägg + Övrigt -->
      <div class="card card-dark">
        <h3>Skägg</h3>
        <p class="card-sub">Trimning &amp; rakning med kniv</p>
        <div class="items">
          {svc.skagg.map(item => (
            <div class="item">
              <div>
                <div class="item-name">{item.name}</div>
                {item.desc && <div class="item-desc">{item.desc}</div>}
              </div>
              <div class="item-price">{item.price}</div>
            </div>
          ))}
        </div>
        <h3 class="sub-heading">Övrigt</h3>
        <p class="card-sub">Detaljer &amp; finish</p>
        <div class="items">
          {svc.ovrigt.map(item => (
            <div class="item">
              <div>
                <div class="item-name">{item.name}</div>
                {item.desc && <div class="item-desc">{item.desc}</div>}
              </div>
              <div class="item-price">{item.price}</div>
            </div>
          ))}
        </div>
      </div>

      <!-- Kombopaket -->
      <div class="card card-cream">
        <h3>Kombopaket</h3>
        <p class="card-sub card-sub-dark">Klippning + skägg, allt på en gång</p>
        <div class="items items-dark">
          {svc.kombo.map(item => (
            <div class="item item-dark">
              <div>
                <div class="item-name">{item.name}</div>
                {item.desc && <div class="item-desc item-desc-dark">{item.desc}</div>}
              </div>
              <div class="item-price item-price-dark">{item.price}</div>
            </div>
          ))}
        </div>
        <a href={settings.booking_url} target="_blank" rel="noopener" class="card-cta">
          Boka kombopaket <span aria-hidden="true">→</span>
        </a>
      </div>

    </div>
    <p class="footnote">{svc.footnote}</p>
  </div>
</section>

<style>
  .services {
    background: #24382E;
    padding: clamp(70px, 9vw, 130px) 24px;
    scroll-margin-top: 70px;
  }
  .services-inner {
    max-width: 1240px;
    margin: 0 auto;
  }
  .services-header {
    max-width: 680px;
    margin-bottom: clamp(40px, 5vw, 70px);
  }
  .label {
    font-family: 'Jost', sans-serif;
    font-size: 13px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: rgba(239, 233, 220, 0.6);
    margin-bottom: 18px;
  }
  h2 {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 600;
    font-size: clamp(32px, 4.6vw, 56px);
    line-height: 1.04;
    letter-spacing: -0.01em;
    color: #EFE9DC;
  }
  .cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(340px, 1fr));
    gap: 20px;
  }
  .card {
    border-radius: 4px;
    padding: 34px clamp(24px, 3vw, 38px);
  }
  .card-dark {
    background: #2E443A;
    border: 1px solid rgba(239, 233, 220, 0.1);
    color: #EFE9DC;
  }
  .card-cream {
    background: #EFE9DC;
    color: #24382E;
    display: flex;
    flex-direction: column;
  }
  h3 {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 600;
    font-size: 30px;
    margin-bottom: 6px;
  }
  .sub-heading {
    margin-top: 34px;
  }
  .card-sub {
    font-family: 'Jost', sans-serif;
    font-size: 13px;
    letter-spacing: 0.04em;
    color: rgba(239, 233, 220, 0.5);
    margin-bottom: 22px;
  }
  .card-sub-dark {
    color: rgba(36, 56, 46, 0.55);
  }
  .items {
    display: flex;
    flex-direction: column;
  }
  .item {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 16px;
    padding: 16px 0;
    border-top: 1px solid rgba(239, 233, 220, 0.12);
  }
  .item-dark {
    border-top-color: rgba(36, 56, 46, 0.16);
  }
  .item-name {
    font-family: 'Jost', sans-serif;
    font-size: 17px;
    font-weight: 400;
  }
  .item-desc {
    font-family: 'Jost', sans-serif;
    font-size: 13px;
    color: rgba(239, 233, 220, 0.55);
    margin-top: 3px;
  }
  .item-desc-dark {
    color: rgba(36, 56, 46, 0.6);
  }
  .item-price {
    font-family: 'Cormorant Garamond', serif;
    font-size: 22px;
    white-space: nowrap;
    color: #EFE9DC;
  }
  .item-price-dark {
    color: #24382E;
  }
  .card-cta {
    margin-top: auto;
    padding-top: 26px;
    color: #24382E;
    text-decoration: none;
    font-family: 'Jost', sans-serif;
    font-size: 14px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-weight: 500;
    display: inline-flex;
    align-items: center;
    gap: 10px;
    transition: gap 0.2s;
  }
  .card-cta:hover { gap: 14px; }
  .footnote {
    margin-top: 26px;
    font-family: 'Jost', sans-serif;
    font-size: 13px;
    color: rgba(239, 233, 220, 0.5);
    letter-spacing: 0.03em;
  }
  @media (max-width: 700px) {
    .cards { grid-template-columns: 1fr; }
  }
</style>
