---
import servicesData from '../../content/services.json';
import settings from '../../content/settings.json';
const { services } = servicesData;
---

<section class="section" id="tjanster">
  <div class="container">
    <p class="section-label">Tjänster & Priser</p>
    <h2>Vad vi erbjuder</h2>
    <div class="divider"></div>

    <div class="services-grid">
      {services.map((s) => (
        <div class="service-item">
          <span class="service-name">{s.name}</span>
          <span class="service-dots"></span>
          <span class="service-price">
            {s.price ? `${s.price} kr` : s.note}
          </span>
        </div>
      ))}
    </div>

    <div class="services-footer">
      <p>Drop-in välkomnas vid lediga tider. Bokning rekommenderas.</p>
      <a href={settings.booking_url} class="btn btn-outline" target="_blank" rel="noopener">Boka tid</a>
    </div>
  </div>
</section>

<style>
  h2 { font-size: clamp(2.2rem, 4vw, 3.2rem); margin-bottom: 0; }
  .services-grid {
    margin-top: 3rem;
    border-top: 1px solid var(--border);
  }
  .service-item {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    padding: 1.25rem 0;
    border-bottom: 1px solid var(--border);
  }
  .service-name {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.25rem;
    font-weight: 500;
    white-space: nowrap;
  }
  .service-dots {
    flex: 1;
    border-bottom: 1px dashed var(--border);
    margin-bottom: 4px;
  }
  .service-price {
    font-size: 0.85rem;
    font-weight: 400;
    letter-spacing: 0.05em;
    color: var(--accent);
    white-space: nowrap;
  }
  .services-footer {
    margin-top: 3rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    flex-wrap: wrap;
  }
  .services-footer p {
    font-size: 0.9rem;
    color: var(--text-muted);
  }
</style>
