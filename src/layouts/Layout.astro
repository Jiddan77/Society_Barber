---
import settings from '../../content/settings.json';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = `${settings.salon_name} – Herrfrisör & Skäggvård i Åkersberga`,
  description = `${settings.salon_name} på ${settings.address}. Herrklippning, fade, skäggtrimning och rakning med kniv. Boka din tid idag.`
} = Astro.props;
---

<!DOCTYPE html>
<html lang="sv">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{title}</title>
  <meta name="description" content={description}>
  <meta name="robots" content="index, follow, max-image-preview:large">
  <link rel="canonical" href="https://societybarber.se/">
  <meta property="og:type" content="business.business">
  <meta property="og:site_name" content={settings.salon_name}>
  <meta property="og:locale" content="sv_SE">
  <meta property="og:url" content="https://societybarber.se/">
  <meta property="og:title" content={`${settings.salon_name} – Din barberare i Åkersberga`}>
  <meta property="og:description" content={description}>
  <meta property="og:image" content="https://societybarber.se/assets/exterior-sign.png">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content={`${settings.salon_name} – Din barberare i Åkersberga`}>
  <meta name="twitter:image" content="https://societybarber.se/assets/exterior-sign.png">
  <link rel="icon" type="image/png" href="/assets/logo-sign.png">
  <link rel="apple-touch-icon" href="/assets/logo-sign.png">
  <meta name="theme-color" content="#1a1a18">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&family=Jost:wght@300;400;500;600&display=swap">

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BarberShop",
    "name": "Society Barber",
    "url": "https://societybarber.se/",
    "image": "https://societybarber.se/assets/exterior-sign.png",
    "telephone": "+46-8-94-10-60",
    "email": "Info@societybarber.se",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "Rallarvägen 43",
      "addressLocality": "Åkersberga",
      "postalCode": "184 40",
      "addressCountry": "SE"
    },
    "geo": {
      "@type": "GeoCoordinates",
      "latitude": 59.4856,
      "longitude": 18.2763
    },
    "openingHoursSpecification": [
      { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"], "opens": "09:00", "closes": "18:00" },
      { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Saturday"], "opens": "10:00", "closes": "17:00" },
      { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Sunday"], "opens": "11:00", "closes": "16:00" }
    ],
    "potentialAction": {
      "@type": "ReserveAction",
      "target": {
        "@type": "EntryPoint",
        "urlTemplate": "https://www.bokadirekt.se/places/society-barber-136520",
        "actionPlatform": ["http://schema.org/DesktopWebPlatform","http://schema.org/MobileWebPlatform"]
      },
      "result": { "@type": "Reservation", "name": "Boka tid" }
    }
  }
  </script>

  <script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
  <script>
    if (window.netlifyIdentity) {
      window.netlifyIdentity.on("init", user => {
        if (!user) {
          window.netlifyIdentity.on("login", () => {
            document.location.href = "/admin/";
          });
        }
      });
    }
  </script>

  <style is:global>
    :root {
      --bg: #1A2A22;
      --bg-light: #223020;
      --text: #F0EAD8;
      --text-muted: #9a9080;
      --accent: #C8B88A;
      --border: rgba(240, 234, 216, 0.15);
    }
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body {
      background: var(--bg);
      color: var(--text);
      font-family: 'Jost', sans-serif;
      font-weight: 300;
      line-height: 1.6;
      overflow-x: hidden;
    }
    img { max-width: 100%; display: block; }
    a { color: inherit; text-decoration: none; }
    h1, h2, h3 { font-family: 'Cormorant Garamond', serif; font-weight: 500; line-height: 1.15; }
    .container { max-width: 1200px; margin: 0 auto; padding: 0 2rem; }
    .section { padding: 7rem 0; }
    .section-label {
      font-family: 'Jost', sans-serif;
      font-size: 0.7rem;
      font-weight: 500;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: var(--text-muted);
      margin-bottom: 1.5rem;
    }
    .btn {
      display: inline-block;
      padding: 0.9rem 2.2rem;
      font-family: 'Jost', sans-serif;
      font-size: 0.75rem;
      font-weight: 500;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      cursor: pointer;
      transition: all 0.2s ease;
    }
    .btn-primary {
      background: var(--text);
      color: var(--bg);
    }
    .btn-primary:hover { background: var(--accent); }
    .btn-outline {
      border: 1px solid var(--text);
      color: var(--text);
    }
    .btn-outline:hover { background: var(--text); color: var(--bg); }
    .divider {
      width: 40px;
      height: 1px;
      background: var(--accent);
      margin: 1.5rem 0;
    }
  </style>
</head>
<body>
  <slot />
</body>
</html>
